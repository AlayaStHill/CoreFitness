{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "SiteSettings": {
    "Language": "en",
    "SiteName": "CoreFitness",
    "CompanyName": "Core Fitness Group",
    "Slogan": "Gym and fitness",
    "Description": "CoreFitness is a gym and fitness center that offers a wide range of services to help you achieve your fitness goals.",
    "Copyright": "All rights reserved"
  },

  "AppCookieSettings": {
    "LoginPath": "/sign-in",
    "LogoutPath": "/",
    "AccessDeniedPath": "/denied",
    "CookieName": "corefitness.auth",
    "ExpiresInDays": 30
  },

  "IdentitySettings": {
    "RequireConfirmedAccount": false,
    "RequireUniqueEmail": true,
    "MinPasswordLength": 8,
    "RequireConfirmedEmail": false,
    "RequireConfirmedPhoneNumber": false
  }

}

 