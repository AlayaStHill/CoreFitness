<section class="my-statistics" aria-label="My Statistics">
    <h2>My Statistics</h2>

    <div class="statistics-card">
        <div class="statistics-item">
            <div class="statistics-item__header">
                <h3>Check-In (last 30 days)</h3>
                <span>25</span>
            </div>
            <div class="statistics-item__progress" role="presentation">
                <span class="statistics-item__fill fill-checkins"></span>
            </div>
        </div>

        <div class="statistics-item">
            <div class="statistics-item__header">
                <h3>Weight Goal</h3>
                <span>50%</span>
            </div>
            <div class="statistics-item__progress" role="presentation">
                <span class="statistics-item__fill fill-weight-goal"></span>
            </div>
        </div>

        <div class="statistics-item">
            <div class="statistics-item__header">
                <h3>Current BMI</h3>
                <span>27</span>
            </div>
            <div class="statistics-item__progress" role="presentation">
                <span class="statistics-item__fill fill-bmi"></span>
            </div>
        </div>
    </div>
</section>
