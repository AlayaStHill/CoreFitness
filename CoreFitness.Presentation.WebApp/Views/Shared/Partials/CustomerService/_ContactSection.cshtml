<section class="customer-service-contact">
    <div class="container">
        <div class="contact-card">
            <div class="contact-image">
                <img src="/images/contact-us-image.webp"
                     alt="Woman training in gym" />

                <div class="contact-overlay">
                    <address class="contact-overlay__column">
                        <div class="contact-overlay__icon" aria-hidden="true">
                            <div class="contact-icon">
                                <img src="/icons/phone.svg" alt="" />
                            </div>
                        </div>
                        <div class="contact-overlay__text">
                            <p class="contact-overlay__label">Phone Number</p>
                            <p class="contact-overlay__value">+(46) 8 410 521 00</p>
                        </div>
                    </address>

                    <address class="contact-overlay__column">
                        <div class="contact-overlay__icon" aria-hidden="true">
                            <div class="contact-icon">
                                <img src="/icons/envelope.svg" alt="" />
                            </div>
                        </div>
                        <div class="contact-overlay__text">
                            <p class="contact-overlay__label">Email Address</p>
                            <p class="contact-overlay__value">info@corefitness.se</p>
                        </div>
                    </address>
                </div>
            </div>

            <div class="contact-content">
                <h2>Contact Us Today</h2>
                <p>
                    Ready to begin your fitness journey? Contact us today and let
                    our expert trainers guide you with the right program and
                    support.
                </p>

                <partial name="~/Views/Shared/Partials/CustomerService/_ContactForm.cshtml" model="Model" />
            </div>
        </div>
    </div>
</section>