<section class="section__customerservice-contact">
    <div class="container">
        <div class="customer-service-card">
            <figure class="customer-service-card-image">
                <img src="/images/contact-us-image.webp"
                     alt="Woman training in gym" />

                <address class="contact-overlay">
                    <div class="contact-overlay__item">
                        <div class="contact-overlay__icon" aria-hidden="true">
                            <div class="contact-icon">
                                <img src="/icons/phone.svg" alt="" />
                            </div>
                        </div>
                        <div class="contact-overlay__text">
                            <p class="contact-overlay__label">Phone Number</p>
                            <a href="tel:+46841052100" class="contact-overlay__value">
                                +(46) 8 410 521 00
                            </a>
                        </div>
                    </div>

                    <div class="contact-overlay__item">
                        <div class="contact-overlay__icon" aria-hidden="true">
                            <div class="contact-icon">
                                <img src="/icons/envelope.svg" alt="" />
                            </div>
                        </div>
                        <div class="contact-overlay__text">
                            <p class="contact-overlay__label">Email Address</p>
                            <a href="mailto:info@corefitness.se"
                                   class="contact-overlay__value">
                                info@corefitness.se
                            </a>
                        </div>
                    </div>
                </address>
            </figure>

            <div class="customer-service-card__content">
                <h2 class="customer-service-card__title">Contact Us Today</h2>
                <p class="customer-service-card__description">
                    Ready to begin your fitness journey? Contact us today and let
                    our expert trainers guide you with the right program and
                    support.
                </p>

                <partial name="~/Views/Shared/Partials/CustomerService/_ContactForm.cshtml" model="Model" />
            </div>
        </div>
    </div>
</section>