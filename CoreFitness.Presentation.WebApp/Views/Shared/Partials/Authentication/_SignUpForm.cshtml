@model SignUpRequest

<form id="signup-form" method="post" asp-action="SignUp" asp-controller="Authentication" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert" aria-live="assertive"></div>

    <div class="form-group form-group--email">
        <label class="form-label" asp-for="Email"></label>
        <input class="form-input" asp-for="Email" autocomplete="email" />
        <span class="field-validation" asp-validation-for="Email"></span>
    </div>

    @* Success message *@
    @{
        string? successMessage = TempData["SuccessMessage"] as string;
    }
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        // avbryter inte annat som läses upp av screen reader. Polite är egentligen implicit med role="status
        <div class="form-success" role="status" aria-live="polite">
            @successMessage
        </div>
    }

    <button class="primary-button form-submit--signup" type="submit">Continue to set password</button>
</form>