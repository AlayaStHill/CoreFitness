@model SetPasswordRequest

<form id="set-password-form" method="post" asp-action="SetPassword" asp-controller="SignUp" aria-describedby="validation-summary" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

    <div class="form-group">
        <label class="form-label" asp-for="Password"></label>
        <input class="form-input" asp-for="Password" autocomplete="new-password" />
        <span class="field-validation" asp-validation-for="Password"></span>
    </div>

    <div class="form-group">
        <label class="form-label" asp-for="ConfirmPassword"></label>
        <input class="form-input" asp-for="ConfirmPassword" autocomplete="new-password" />
        <span class="field-validation" asp-validation-for="ConfirmPassword"></span>
    </div>

    <div class="form-checkbox">
        <input class="form-checkbox__input" type="checkbox" asp-for="TermsAndConditions" />
        <label class="form-checkbox__label" asp-for="TermsAndConditions"></label>  
        <span class="field-validation" asp-validation-for="TermsAndConditions"></span>
    </div>
  

    <div class="form-submit-group">
        <button class="primary-button primary-button--full form-submit" type="submit">Continue to account</button>
        <div class="form-feedback">
            @* Success message *@
            @{
                string? successMessage = TempData["SuccessMessage"] as string;
            }
            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                // avbryter inte annat som läses upp av screen reader. Polite är egentligen implicit med role="status
                <div class="form-success" role="status" aria-live="polite">
                    @successMessage
                </div>
            }
            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert" aria-live="assertive"></div>
        </div>
    </div>
</form>