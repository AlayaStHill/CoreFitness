@{
    ViewData["Title"] = "Page Not Found";
}

<section class="notfound-section">
    <div class="container">
        <img src="~/images/404-error-img.webp" alt="Illustration showing a 404 page not found error" />

        <div class="notfound-content">
            <h1>Oops! page not found</h1>
            <p>The page you are looking for does not exist.</p>
            <a asp-controller="Home" asp-action="Index" class="primary-button">Back to Homepage</a>
        </div>
    </div>
</section>