@model SetPasswordRequest

@{
    ViewData["Title"] = "Set Password";
    Layout = "Layouts/_AuthLayout";
}

<section class="auth-layout">
    <div class="container container-narrow">
        <div class="auth-card">
            <h1 class="auth-card__title">Set Your Password</h1>
            <p class="auth-card__description">
                Set a strong password to protect your account. For security reasons, your password must be at least 8 characters long 
                and include uppercase and lowercase letters, numbers, and special characters.
            </p>

            <partial name="Partials/Authentication/_SetPasswordForm" model="Model" />
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/set-password-form.js" asp-append-version="true"></script>
}