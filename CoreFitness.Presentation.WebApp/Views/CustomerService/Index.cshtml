@model ContactForm

@{
    ViewData["Title"] = "Customer Service";
}

<section class="page-title">
    <div class="container">
        <h1>Customer Service</h1>
    </div>
</section>

@* CONTACT *@
<section class="customer-service-contact">
    <div class="container">
        <div class="contact-card">
            <div class="contact-image">
                <img src="/images/contact-us-image.webp"
                     alt="Woman training in gym" />

                <div class="contact-overlay">
                    <address class="contact-overlay__column">
                        <div class="contact-overlay__icon" aria-hidden="true">
                            <div class="contact-icon">
                                <img src="/icons/phone.svg" alt="" />
                            </div>
                        </div>
                        <div class="contact-overlay__text">
                            <p class="contact-overlay__label">Phone Number</p>
                            <p class="contact-overlay__value">+(46) 8 410 521 00</p>
                        </div>
                    </address>

                    <address class="contact-overlay__column">
                        <div class="contact-overlay__icon" aria-hidden="true">
                            <div class="contact-icon">
                                <img src="/icons/envelope.svg" alt="" />
                            </div>
                        </div>
                        <div class="contact-overlay__text">
                            <p class="contact-overlay__label">Email Address</p>
                            <p class="contact-overlay__value">info@corefitness.se</p>
                        </div>
                    </address>
                </div>
            </div>

            <div class="contact-content">
                <h2>Contact Us Today</h2>
                <p>
                    Ready to begin your fitness journey? Contact us today and let
                    our expert trainers guide you with the right program and
                    support.
                </p>

                @* Success message *@
                @if (TempData["ContactFormMessage"] != null)
                {
                    <div role="status">
                        @TempData["ContactFormMessage"]
                    </div>
                }

                <!-- CONTACTFORM -->
                <div class="contact-form-wrapper">
                    <div class="container">
                        <form class="contact-form" asp-controller="CustomerService" asp-action="Index" method="post" novalidate>
                            @Html.AntiForgeryToken()

                            @* Sammanställning av fel från ModelState, inte kopplat till ett specifikt fält - if (!ModelState.IsValid). Role alert - screen reader läsaer upp direkt *@
                            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

                            <div class="form-group">
                                <label class="form-label" asp-for="FirstName"></label>
                                <input class="form-input" asp-for="FirstName" placeholder="Enter First Name" />
                                <span class="field-validation" asp-validation-for="FirstName"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label" asp-for="LastName"></label>
                                <input class="form-input" asp-for="LastName" placeholder="Enter Last Name" />
                                <span class="field-validation" asp-validation-for="LastName"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label" asp-for="Email"></label>
                                <input type="email" class="form-input" asp-for="Email" placeholder="name@example.com" />
                                <span class="field-validation" asp-validation-for="Email"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label" asp-for="PhoneNumber"></label>
                                <input type="tel" class="form-input" asp-for="PhoneNumber" placeholder="Enter Phone Number" />
                                <span class="field-validation" asp-validation-for="PhoneNumber"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label" asp-for="Message"></label>
                                <textarea class="form-input" asp-for="Message" placeholder="Message..."></textarea>
                                <span class="field-validation" asp-validation-for="Message"></span>
                            </div>

                            <button class="primary-button" type="submit">Submit Message</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


@* FAQ *@
<section class="customer-service-faq">
    <div class="container">
        <h2>Common questions about gym and training</h2>
    </div>
</section>