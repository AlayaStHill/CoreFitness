@{
    ViewData["Title"] = "Customer Service";
}

<section class="page-title">
    <div class="container">
        <h1>Customer Service</h1>
    </div>
</section>

@* CONTACT *@
<section class="customer-service-contact">
    <div class="container">

        <div class="contact-layout">
            <div class="contact-image">
                <img src="/images/contact-us-image.webp" alt="Woman training in gym" />
            </div>

            <h2>Contact Us Today</h2>
            <p>
                Ready to begin your fitness journey? Contact us today and let our
                expert trainers guide you with the right program and support.
            </p>

            <!-- FORM KOMMER SENARE -->
            <div class="contact-form-placeholder"></div>
        </div>
    </div> 
</section>


@* FAQ *@
<section class="customer-service-faq">
    <div class="container">
        <h2>Common questions about gym and training</h2>
    </div>
</section>