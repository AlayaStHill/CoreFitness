@{
    ViewData["Title"] = "Our Memberships";
}

<div class="our-memberships-page container">

    <section class="page-title">
        <div class="container">
            <h1>Our Membership Offers</h1>
        </div>
    </section>
    <section class="our-memberships-section">
        <div class="our-membership-offers">
            <div class="membership-card">
                <div class="content-wrapper">
                    <img class="icon" src="icons/dumbell.svg" alt="dumbell icon">
                    <h3 class="membership-title">Standard Membership</h3>
                    <hr>
                    <p>
                        With the Standard Membership, get access
                        to our full range of gym facilities.
                    </p>
                    <ul class="membership-includes">
                        <li><img src="icons/check-bot.svg" alt="Check icon">Access to all gym equipment</li>
                        <li><img src="icons/check-bot.svg" alt="Check icon">Locker room access</li>
                        <li><img src="icons/check-bot.svg" alt="Check icon">Free Wi-Fi</li>
                    </ul>
                </div>

                <div class="price-info-section">
                    <div class="upper">
                        <div class="price-info">
                            <p class="price">495.00 <span>/monthly</span></p>
                            <p class="price-description">* Monthly 20 Classes</p>
                        </div>
                        <a href="/signup" class="primary-button">
                            Join now
                        </a>
                    </div>
                    <hr>

                    <p class="try-free">Try Any Membership Free for 1 Week</p>
                </div>
            </div>
            <div class="membership-card">
                <div class="content-wrapper">
                    <img class="icon" src="icons/dumbell.svg" alt="dumbell icon">
                    <h3 class="membership-title">Standard Membership</h3>
                    <hr>
                    <p>
                        With the Standard Membership, get access
                        to our full range of gym facilities.
                    </p>
                    <ul class="membership-includes">
                        <li><img src="icons/check-bot.svg" alt="Check icon">Access to all gym equipment</li>
                        <li><img src="icons/check-bot.svg" alt="Check icon">Locker room access</li>
                        <li><img src="icons/check-bot.svg" alt="Check icon">Free Wi-Fi</li>
                    </ul>
                </div>

                <div class="price-info-section">
                    <div class="upper">
                        <div class="price-info">
                            <p class="price">495.00 <span>/monthly</span></p>
                            <p class="price-description">* Monthly 20 Classes</p>
                        </div>
                        <a href="/signup" class="primary-button">
                            Join now
                        </a>
                    </div>
                    <hr>

                    <p class="try-free">Try Any Membership Free for 1 Week</p>
                </div>
            </div>
            <div class="call-us-card">
                <div class="title">
                    <h3>Get Your Membership</h3>
                    <p>
                        Our memberships give you access to all
                        equipment, personalized training.
                    </p>
                </div>
                <hr>
                <h3 class="phone-info">Call Us At: +(46) 8 410 521 00</h3>
                <a href="tel:+46763233430" class="primary-button"
                       aria-label="Call CoreFitness at +46 8 410 521 00">
                    Call Us Today!
                </a>
            </div>


        </div>
        <div class="membership-info">
            <div>
                <img src="icons/checkbox.svg" alt="Checkbox icon">
                <p>Get 30 day free trial</p>
            </div>
            <div>
                <img src="icons/wallet.svg" alt="Wallet icon">
                <p>No any hidden fees pay</p>
            </div>
            <div>
                <img src="icons/clock.svg" alt="Clock icon">
                <p>You can cancel anytime</p>
            </div>
        </div>
    </section>

    <section class="customer-service-faq">
        <div class="container">
            <div class="customer-service-card">
                <figure class="customer-service-card-image">
                    <img src="/images/faqs-image.webp" alt="Man training in gym" />
                </figure>

                <div class="customer-service-card__content customer-service-card__content--faq">
                    <span class="section-label">Frequently Asked Questions</span>

                    <h2>Common questions about gym and training</h2>

                    <div class="faq-accordion">
                        <details open class="faq-item">
                            <summary>
                                <span class="faq-question">
                                    Q1. Do I need prior gym experience to join
                                    CoreFitness?
                                </span>
                                <span class="faq-toggle" aria-hidden="true"></span>
                            </summary>
                            <div class="faq-item__content">
                                <p>
                                    No. Our memberships are built for all fitness levels, and
                                    our trainers can help you get started with a safe plan and
                                    proper technique.
                                </p>
                                <ul>
                                    <li>Intro session available for new members</li>
                                    <li>Beginner-friendly programs that scale with you</li>
                                </ul>
                            </div>
                        </details>

                        <details class="faq-item">
                            <summary>
                                <span class="faq-question">
                                    Q2. What facilities are included with the
                                    membership?
                                </span>
                                <span class="faq-toggle" aria-hidden="true"></span>
                            </summary>
                            <div class="faq-item__content">
                                <p>
                                    Access varies by membership tier, but typically includes
                                    gym equipment, changing rooms, and selected group classes.
                                </p>
                            </div>
                        </details>

                        <details class="faq-item">
                            <summary>
                                <span class="faq-question">
                                    Q3. Can I try the gym before taking a
                                    membership?
                                </span>
                                <span class="faq-toggle" aria-hidden="true"></span>
                            </summary>
                            <div class="faq-item__content">
                                <p>
                                    Yes. Contact us and we’ll help you book a trial visit so
                                    you can see the facilities and meet the team.
                                </p>
                            </div>
                        </details>

                        <details class="faq-item">
                            <summary>
                                <span class="faq-question">
                                    Q4. Are there group workout programs
                                    available?
                                </span>
                                <span class="faq-toggle" aria-hidden="true"></span>
                            </summary>
                            <div class="faq-item__content">
                                <p>
                                    Yes. We offer group training options at different levels,
                                    depending on your location and schedule.
                                </p>
                            </div>
                        </details>

                        <details class="faq-item">
                            <summary>
                                <span class="faq-question">
                                    Q5. Is nutrition guidance included in the
                                    plans?
                                </span>
                                <span class="faq-toggle" aria-hidden="true"></span>
                            </summary>
                            <div class="faq-item__content">
                                <p>
                                    Some plans include nutrition support. If it’s not
                                    included, we can recommend add-ons or coaching options.
                                </p>
                            </div>
                        </details>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
